# Stripe — set these as Environment Variables in the Vercel project (not committed).
# Use TEST keys (sk_test_… / price in test mode) until you're ready to go live.

# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx

# Price ID of your recurring subscription product
# (Stripe → Product catalog → create product → add a recurring price → copy price_…)
STRIPE_PRICE_ID=price_xxx

# Optional free-trial length in days (omit for no trial)
STRIPE_TRIAL_DAYS=14

# Webhook signing secret (only needed if you enable api/webhook.js)
# Stripe → Developers → Webhooks → add endpoint https://YOURAPP.vercel.app/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx
